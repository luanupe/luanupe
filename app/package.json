{
  "name": "github-stats",
  "version": "0.3.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node -r newrelic dist/server.js",
    "dev": "nodemon --watch src --ext ts --legacy-watch --exec tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "bentocache": "^1.6.1",
    "express": "^5.1.0",
    "newrelic": "^13.6.7",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.2",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
